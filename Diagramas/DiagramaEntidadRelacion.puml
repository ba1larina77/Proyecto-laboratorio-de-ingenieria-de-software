@startuml diagrama de clases
hide circle
skinparam linetype ortho
skinparam EntityBackgroundColor #F9F9F9
skinparam EntityBorderColor #333333

entity "Rol" as rol {
  * id_rol : INT <<PK>>
  --
  nombre_rol : VARCHAR
}

entity "Usuario" as usuario {
  * id_usuario : INT <<PK>>
  --
  id_rol : INT <<FK>>
  DNI : VARCHAR
  nombres : VARCHAR
  apellidos : VARCHAR
  fecha_nacimiento : DATE
  lugar_nacimiento : VARCHAR
  direccion_envio : VARCHAR
  genero : VARCHAR
  correo : VARCHAR
  nombre_usuario : VARCHAR
  contrasena : VARCHAR
}

entity "Preferencia_Literaria" as pref_lit {
  * id_preferencia : INT <<PK>>
  --
  tipo_preferencia : VARCHAR
  valor : VARCHAR
}

entity "Usuario_Preferencia" as usu_pref {
  * id_usuario : INT <<FK>>
  * id_preferencia : INT <<FK>>
}

entity "Informacion_Financiera" as info_fin {
  * id_financiera : INT <<PK>>
  --
  id_usuario : INT <<FK>>
  tipo_tarjeta : VARCHAR
  numero_tarjeta : VARCHAR
  saldo : DECIMAL
}

entity "Autor" as autor {
  * id_autor : INT <<PK>>
  --
  nombre_autor : VARCHAR
}

entity "Genero" as genero {
  * id_genero : INT <<PK>>
  --
  nombre_genero : VARCHAR
}

entity "Editorial" as editorial {
  * id_editorial : INT <<PK>>
  --
  nombre_editorial : VARCHAR
}

entity "Libro" as libro {
  * id_libro : INT <<PK>>
  --
  titulo : VARCHAR
  id_autor : INT <<FK>>
  año_publicacion : INT
  id_genero : INT <<FK>>
  numero_paginas : INT
  id_editorial : INT <<FK>>
  ISSN : VARCHAR
  idioma : VARCHAR
  fecha_publicacion : DATE
  precio : DECIMAL
}

entity "Tienda" as tienda {
  * id_tienda : INT <<PK>>
  --
  nombre_tienda : VARCHAR
  direccion : VARCHAR
  latitud : DECIMAL
  longitud : DECIMAL
}

entity "Ejemplar" as ejemplar {
  * id_ejemplar : INT <<PK>>
  --
  codigo_unico : VARCHAR
  id_libro : INT <<FK>>
  estado_conservacion : VARCHAR
  historico_agotado : BOOLEAN
  id_tienda : INT <<FK>>
}

entity "Carrito" as carrito {
  * id_carrito : INT <<PK>>
  --
  id_usuario : INT <<FK>>
}

entity "Detalle_Carrito" as det_carrito {
  * id_carrito : INT <<FK>>
  * id_ejemplar : INT <<FK>>
}

entity "Reserva" as reserva {
  * id_reserva : INT <<PK>>
  --
  id_usuario : INT <<FK>>
  fecha_hora_reserva : DATETIME
  estado_reserva : VARCHAR
}

entity "Detalle_Reserva" as det_reserva {
  * id_reserva : INT <<FK>>
  * id_ejemplar : INT <<FK>>
}

entity "Compra" as compra {
  * id_compra : INT <<PK>>
  --
  id_usuario : INT <<FK>>
  id_financiera : INT <<FK>>
  fecha_hora_compra : DATETIME
  estado_envio : VARCHAR
  direccion_envio : VARCHAR
  id_tienda_recogida : INT <<FK>>
}

entity "Detalle_Compra" as det_compra {
  * id_compra : INT <<FK>>
  * id_ejemplar : INT <<FK>>
}

entity "Devolucion" as devolucion {
  * id_devolucion : INT <<PK>>
  --
  id_detalle_compra : INT <<FK>>
  motivo_principal : VARCHAR
  descripcion_ampliada : TEXT
  fecha_solicitud : DATETIME
  codigo_qr : VARCHAR
}

entity "Noticia" as noticia {
  * id_noticia : INT <<PK>>
  --
  titulo : VARCHAR
  contenido : TEXT
  id_libro_asociado : INT <<FK>>
  fecha_publicacion : DATETIME
}

entity "Suscripcion_Noticia" as sus_noticia {
  * id_usuario : INT <<FK>>
  * estado_suscripcion : VARCHAR
}

entity "Mensaje" as mensaje {
  * id_mensaje : INT <<PK>>
  --
  id_remitente : INT <<FK>>
  id_destinatario : INT <<FK>>
  contenido : TEXT
  fecha_hora_envio : DATETIME
}

' Relaciones
rol ||--o{ usuario
usuario ||--|| info_fin
usuario ||--o{ usu_pref
pref_lit ||--o{ usu_pref

autor ||--o{ libro
genero ||--o{ libro
editorial ||--o{ libro
libro ||--o{ ejemplar
tienda |o--o{ ejemplar

usuario ||--|| carrito
carrito ||--o{ det_carrito
ejemplar ||--o{ det_carrito

usuario ||--o{ reserva
reserva ||--o{ det_reserva
ejemplar ||--o{ det_reserva

usuario ||--o{ compra
info_fin ||--o{ compra
tienda |o--o{ compra
compra ||--o{ det_compra
ejemplar ||--o{ det_compra

det_compra ||--o| devolucion

libro |o--o{ noticia
usuario ||--|| sus_noticia

usuario ||--o{ mensaje : remitente
usuario ||--o{ mensaje : destinatario

@enduml